{
  "name": "project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.14",
  "prisma": {
    "schema": "infrastructure/database/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next node_modules bun.lockb",
    "build:all": "bun run lint && bun run format && bunx tsc --noEmit && bun run build",
    "db:generate": "prisma generate --schema=./infrastructure/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./infrastructure/database/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=./infrastructure/database/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=./infrastructure/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./infrastructure/database/prisma/schema.prisma",
    "test": "bun test",
    "test:unit": "bun test __tests__/unit",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage __tests__/unit __tests__/integration",
    "test:ci": "bun test __tests__/unit --coverage && bun test __tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:seed": "bun __tests__/helpers/e2e-seed.ts",
    "lighthouse": "lhci autorun",
    "lighthouse:ci": "lhci autorun --upload.target=temporary-public-storage",
    "playwright:install": "playwright install",
    "bundle-analyze": "ANALYZE=true bun run build",
    "load-test": "k6 run scripts/load-test.js",
    "load-test:prod": "k6 run --env BASE_URL=${PROD_URL:-https://your-app.com} scripts/load-test.js",
    "gdpr:purge": "bun run scripts/gdpr-data-purge.ts",
    "gdpr:purge:dry-run": "bun run scripts/gdpr-data-purge.ts --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.946.0",
    "@aws-sdk/lib-storage": "^3.946.0",
    "@aws-sdk/s3-request-presigner": "^3.946.0",
    "@hookform/resolvers": "^5.2.2",
    "@invertase/firestore-stripe-payments": "^0.0.8",
