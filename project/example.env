# ============================================================================
# App & Environment
# ============================================================================
APP_ENV=development
# Options: development, production, test

NODE_ENV=development
# Standard Node.js environment variable
# Options: development, production, test

NEXT_PUBLIC_APP_ENV=development
# Public version of APP_ENV (exposed to browser)
# Options: development, production, test

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/your_app
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Database connection settings (for Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=your_app

# Enable database health checks
ENABLE_DB_HEALTH_CHECKS=false

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://localhost:6379
# Format: redis://HOST:PORT or redis://USER:PASSWORD@HOST:PORT

# Redis connection settings (for Docker Compose)
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# Firebase Client (NEXT_PUBLIC_* - exposed to browser)
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

MEASUREMENT_ID=G-XXXXXXXXXX
# Google Analytics Measurement ID (optional)

# ============================================================================
# Firebase Admin (Server-side only)
# ============================================================================
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
# Note: Private key should be wrapped in quotes and include \n for newlines

# ============================================================================
# Security
# ============================================================================
CSRF_SECRET=your-32-byte-hex-string-here
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes) for AES-256
ENCRYPTION_KEY=your-encryption-key-32-characters-long
ADMIN_SPECIAL_CODE_HASH=your-bcrypt-hash-of-admin-code

# ============================================================================
# Stripe
# ============================================================================
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Get this from Stripe Dashboard > Developers > Webhooks > Your endpoint > Signing secret

# ============================================================================
# Email (Resend)
# ============================================================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_REPLY_TO_EMAIL=support@yourdomain.com

# ============================================================================
# Storage (Cloudflare R2)
# ============================================================================
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.r2.dev
R2_ENABLED=false
# Set to true to enable R2 storage

# ============================================================================
# CORS
# ============================================================================
CORS_ALLOWED_ORIGINS=https://your-app.com,https://www.your-app.com,https://your-app-production.up.railway.app
# Comma-separated list of allowed origins

# ============================================================================
# Debug & Logging
# ============================================================================
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_LOG_LEVEL=debug
# Options: debug, info, warn, error

# ============================================================================
# SEO & Metadata
# ============================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Your production URL: https://yourdomain.com

# ============================================================================
# Testing & CI
# ============================================================================
E2E_BASE_URL=http://localhost:3000
CI=false
# Set to true in CI/CD environments

METRICS_SECRET=<long random string>