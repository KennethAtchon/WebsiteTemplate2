# Docker Infrastructure Environment Variables
# Copy this file to .env and fill in your actual values
# This file contains ONLY infrastructure-related configuration

# Environment
NODE_ENV=development

# Database Infrastructure
POSTGRES_DB=website_template
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# External Service URLs (for cross-service communication)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Network Configuration
NETWORK_NAME=website-template-network

# Production Configuration
DOMAIN_NAME=localhost
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem
