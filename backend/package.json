{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.14",
  "prisma": {
    "schema": "src/infrastructure/database/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate --schema=./src/infrastructure/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./src/infrastructure/database/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=./src/infrastructure/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./src/infrastructure/database/prisma/schema.prisma",
    "test": "bun test",
    "test:unit": "bun test __tests__/unit",
    "test:ci": "bun test __tests__/unit --coverage && bun test __tests__/integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.946.0",
    "@aws-sdk/lib-storage": "^3.946.0",
    "@aws-sdk/s3-request-presigner": "^3.946.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.3.0",
    "firebase-admin": "^13.6.0",
    "formidable": "^3.5.4",
    "hono": "^4.7.0",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.576.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.0",
    "prom-client": "^15.1.3",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/formidable": "^3.4.6",
    "@types/node": "^25.3.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3"
  }
}
