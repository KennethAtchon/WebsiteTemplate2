{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite preview",
    "lint": "eslint . --max-warnings 999",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules bun.lock",
    "build:all": "bun run lint && bun run format && bunx tsc --noEmit && bun run build",
    "test": "bun test",
    "test:unit": "bun test __tests__/unit",
    "test:integ": "bun test __tests__/integration",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage __tests__/unit",
    "test:ci": "bun test __tests__/unit --coverage",
    "bundle-analyze": "ANALYZE=true bun run build",
    "i18n:check": "bun scripts/fix-i18n-interpolation.ts",
    "i18n:fix": "bun scripts/fix-i18n-interpolation.ts --fix"
  },
